# Telegram API 凭证（从 https://my.telegram.org 获取）
TG_API_ID=12345678
TG_API_HASH=your_api_hash_here

# 要监控的群组（逗号分隔，支持 username 或 invite link）
TG_TARGET_GROUPS=groupusername1,groupusername2

# 要监控的群友 username（不含@，逗号分隔）
TG_TARGET_USERS=friend1,friend2

# 你自己的 Telegram User ID（可以发消息给 @userinfobot 获取）
TG_MY_USER_ID=123456789

# 炸弹指数追踪的目标用户 username（不含@）
TG_BOMB_TARGET=someusername

# 大模型 API Key（二选一，优先使用千问；都填则千问优先）
QIANWEN_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# 可选配置
SENTIMENT_WINDOW_SIZE=3          # 连续几条消息判断一次
SENTIMENT_EXTREME_THRESHOLD=0.75 # 极端阈值 (0~1)
SENTIMENT_COOLDOWN_MINUTES=30    # 提醒冷却时间（分钟）
